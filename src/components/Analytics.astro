---
// Analytics component for Vercel Analytics and Speed Insights
// Only loads in Vercel production environment
---

<!-- Vercel Analytics -->
<script>
  // Only load if we're on Vercel (check for vercel runtime)
  if (typeof window !== 'undefined' && import.meta.env.PROD && import.meta.env.VERCEL) {
    import('@vercel/analytics').then(({ inject }) => {
      inject();
    }).catch(() => {
      // Silently fail if not on Vercel
    });
  }
</script>

<!-- Vercel Speed Insights -->
<script>
  if (typeof window !== 'undefined' && import.meta.env.PROD && import.meta.env.VERCEL) {
    import('@vercel/speed-insights').then(({ injectSpeedInsights }) => {
      injectSpeedInsights();
    }).catch(() => {
      // Silently fail if not on Vercel
    });
  }
</script>
