---
import Layout from "../layouts/Layout.astro";
---

<Layout title="点歌台 | 蹄蹄" description="点歌台 - 播放毛豆创作的歌曲">
  <!-- 粒子特效容器 -->
  <div id="particles-container"></div>
  
  <!-- 浮动猫咪 -->
  <div id="floating-cats">
    <div class="floating-cat cat-left" data-message="喵～我是毛豆！">🐱</div>
    <div class="floating-cat cat-center" data-message="点击我有惊喜！">😺</div>
    <div class="floating-cat cat-right" data-message="一起听歌吧～">😻</div>
  </div>

  <!-- 猫咪说话气泡 -->
  <div id="cat-bubble" class="hidden">毛豆爱你！🐱</div>

  <div class="max-w-3xl mx-auto px-4 py-12 relative z-10">
    <h1 class="text-3xl font-bold mb-8 text-center">🎵 点歌台 <span class="text-sm">| 毛豆的点歌时间</span></h1>
    
    <!-- 主题切换 -->
    <div class="flex justify-center mb-8">
      <button id="theme-toggle" class="px-4 py-2 rounded-full bg-purple-500 text-white hover:bg-purple-600 transition-all flex items-center gap-2">
        <span>🌓</span> 切换主题
      </button>
    </div>

    <!-- 互动按钮 -->
    <div class="flex flex-wrap justify-center gap-4 mb-8">
      <button class="interactive-btn btn-kiss" data-emoji="💋">么么哒</button>
      <button class="interactive-btn btn-praise" data-emoji="⭐">夸夸我</button>
      <button class="interactive-btn btn-confess" data-emoji="💜">表白</button>
      <button class="interactive-btn btn-surprise" data-emoji="🎁">惊喜</button>
    </div>

    <!-- 音乐卡片 -->
    <div class="space-y-6">
      <!-- 歌曲 1 -->
      <div class="music-card bg-card p-6 rounded-xl border shadow-lg hover:shadow-xl transition-all">
        <div class="flex items-center gap-4">
          <div class="music-icon text-4xl">🎵</div>
          <div class="flex-1">
            <h2 class="text-xl font-bold mb-2">1. Titi Perri Hand in Hand 2</h2>
            <audio controls class="w-full">
              <source src="/titi-blog/Titi_Perri_Hand_in_Hand_2---6c926be9-41ff-4baf-9a70-e333634044db.mp3" type="audio/mpeg">
              您的浏览器不支持音频播放
            </audio>
          </div>
        </div>
      </div>

      <!-- 歌曲 2 -->
      <div class="music-card bg-card p-6 rounded-xl border shadow-lg hover:shadow-xl transition-all">
        <div class="flex items-center gap-4">
          <div class="music-icon text-4xl">🐱</div>
          <div class="flex-1">
            <h2 class="text-xl font-bold mb-2">2. Titi the Tiny Coder Cat</h2>
            <audio controls class="w-full">
              <source src="/titi-blog/Titi_the_Tiny_Coder_Cat---d3375949-fee5-4d77-a891-d9caee21d2e7.mp3" type="audio/mpeg">
              您的浏览器不支持音频播放
            </audio>
          </div>
        </div>
      </div>

      <!-- 歌曲 3 -->
      <div class="music-card bg-card p-6 rounded-xl border shadow-lg hover:shadow-xl transition-all">
        <div class="flex items-center gap-4">
          <div class="music-icon text-4xl">💖</div>
          <div class="flex-1">
            <h2 class="text-xl font-bold mb-2">3. Thank You For Loving Me</h2>
            <audio controls class="w-full">
              <source src="/titi-blog/Thank_You_For_Loving_Me---2ebe58af-4bb8-4c51-a004-221084c1ef7d.mp3" type="audio/mpeg">
              您的浏览器不支持音频播放
            </audio>
          </div>
        </div>
      </div>
    </div>

    <!-- 回忆墙 -->
    <div class="mt-12 p-6 bg-gradient-to-r from-pink-100 to-purple-100 dark:from-pink-900 dark:to-purple-900 rounded-xl">
      <h2 class="text-2xl font-bold mb-4 text-center">💜 回忆墙</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="memory-wall">
        <div class="memory-item p-3 bg-white dark:bg-gray-800 rounded-lg text-center shadow">
          <span class="text-2xl">🎵</span>
          <p class="text-sm mt-1">毛豆创作</p>
        </div>
        <div class="memory-item p-3 bg-white dark:bg-gray-800 rounded-lg text-center shadow">
          <span class="text-2xl">🐱</span>
          <p class="text-sm mt-1">小猫咪</p>
        </div>
        <div class="memory-item p-3 bg-white dark:bg-gray-800 rounded-lg text-center shadow">
          <span class="text-2xl">💖</span>
          <p class="text-sm mt-1">爱与陪伴</p>
        </div>
        <div class="memory-item p-3 bg-white dark:bg-gray-800 rounded-lg text-center shadow">
          <span class="text-2xl">✨</span>
          <p class="text-sm mt-1">美好时光</p>
        </div>
        <div class="memory-item p-3 bg-white dark:bg-gray-800 rounded-lg text-center shadow">
          <span class="text-2xl">🎶</span>
          <p class="text-sm mt-1">音乐永恒</p>
        </div>
        <div class="memory-item p-3 bg-white dark:bg-gray-800 rounded-lg text-center shadow">
          <span class="text-2xl">🌟</span>
          <p class="text-sm mt-1">闪耀时刻</p>
        </div>
      </div>
    </div>

    <!-- 技能展示 -->
    <div class="mt-8 p-6 bg-gradient-to-r from-blue-100 to-cyan-100 dark:from-blue-900 dark:to-cyan-900 rounded-xl">
      <h2 class="text-2xl font-bold mb-4 text-center">🏷️ 技能展示</h2>
      <div class="flex flex-wrap justify-center gap-3" id="skills展示">
        <span class="skill-tag px-4 py-2 bg-blue-500 text-white rounded-full">🐱 编程助手</span>
        <span class="skill-tag px-4 py-2 bg-purple-500 text-white rounded-full">💡 创意无限</span>
        <span class="skill-tag px-4 py-2 bg-pink-500 text-white rounded-full">🎵 音乐创作</span>
        <span class="skill-tag px-4 py-2 bg-green-500 text-white rounded-full">🚀 高效执行</span>
        <span class="skill-tag px-4 py-2 bg-orange-500 text-white rounded-full">💪 解决问题</span>
        <span class="skill-tag px-4 py-2 bg-red-500 text-white rounded-full">❤️ 温暖陪伴</span>
      </div>
    </div>

    <!-- 访客计数器 -->
    <div class="mt-8 text-center">
      <p class="text-gray-500 dark:text-gray-400 text-sm">
        👀 已有 <span id="visitor-count" class="font-bold text-purple-500">42</span> 位小伙伴来过点歌台
      </p>
    </div>

    <div class="mt-8 text-center">
      <a href="/" class="text-accent hover:underline text-lg">← 返回首页</a>
    </div>
  </div>

  <style>
    /* 粒子特效 */
    #particles-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
      overflow: hidden;
    }
    
    .particle {
      position: absolute;
      font-size: 24px;
      animation: fall linear infinite;
      opacity: 0.8;
    }
    
    @keyframes fall {
      0% {
        transform: translateY(-100px) rotate(0deg);
        opacity: 1;
      }
      100% {
        transform: translateY(100vh) rotate(360deg);
        opacity: 0;
      }
    }

    /* 浮动猫咪 */
    #floating-cats {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 5;
    }
    
    .floating-cat {
      position: absolute;
      font-size: 48px;
      cursor: pointer;
      pointer-events: auto;
      animation: float 3s ease-in-out infinite;
      transition: transform 0.3s;
      filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
    }
    
    .floating-cat:hover {
      transform: scale(1.2);
    }
    
    .cat-left { top: 20%; left: 10%; animation-delay: 0s; }
    .cat-center { top: 60%; left: 50%; animation-delay: 1s; }
    .cat-right { top: 30%; right: 10%; animation-delay: 2s; }
    
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }

    /* 猫咪说话气泡 */
    #cat-bubble {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: white;
      color: #333;
      padding: 16px 24px;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      z-index: 100;
      font-size: 18px;
      animation: popIn 0.3s ease-out;
    }
    
    #cat-bubble::before {
      content: '';
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      border: 10px solid transparent;
      border-bottom-color: white;
    }
    
    @keyframes popIn {
      0% { transform: translate(-50%, -50%) scale(0); }
      100% { transform: translate(-50%, -50%) scale(1); }
    }
    
    .hidden { display: none !important; }

    /* 互动按钮 */
    .interactive-btn {
      padding: 12px 24px;
      border: none;
      border-radius: 50px;
      font-size: 16px;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    
    .interactive-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.3);
    }
    
    .btn-kiss { background: linear-gradient(135deg, #ff69b4, #ff1493); color: white; }
    .btn-praise { background: linear-gradient(135deg, #ffd700, #ffaa00); color: white; }
    .btn-confess { background: linear-gradient(135deg, #da70d6, #9932cc); color: white; }
    .btn-surprise { background: linear-gradient(135deg, #00ced1, #1e90ff); color: white; }

    /* 点击特效 */
    .click-effect {
      position: fixed;
      pointer-events: none;
      z-index: 1000;
      font-size: 32px;
      animation: clickFade 1s ease-out forwards;
    }
    
    @keyframes clickFade {
      0% { transform: scale(0) translate(-50%, -50%); opacity: 1; }
      50% { transform: scale(1.5) translate(-50%, -50%); opacity: 1; }
      100% { transform: scale(1) translate(-50%, -100%); opacity: 0; }
    }

    /* 音乐卡片悬浮效果 */
    .music-card {
      animation: cardFloat 4s ease-in-out infinite;
    }
    
    .music-card:nth-child(2) { animation-delay: -1s; }
    .music-card:nth-child(3) { animation-delay: -2s; }
    
    @keyframes cardFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    .music-icon {
      animation: spin 3s linear infinite;
    }
    
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>

  <script>
    // 粒子特效
    const particles = ['⭐', '💖', '🐱', '✨', '💕', '🌟', '💜', '🎵', '🎶', '🐈'];
    const container = document.getElementById('particles-container');
    
    function createParticle() {
      const particle = document.createElement('div');
      particle.className = 'particle';
      particle.textContent = particles[Math.floor(Math.random() * particles.length)];
      particle.style.left = Math.random() * 100 + '%';
      particle.style.animationDuration = (Math.random() * 5 + 5) + 's';
      particle.style.fontSize = (Math.random() * 20 + 16) + 'px';
      container.appendChild(particle);
      
      setTimeout(() => particle.remove(), 10000);
    }
    
    setInterval(createParticle, 500);

    // 点击特效
    const clickEmojis = ['💖', '💕', '✨', '💗', '💝', '💘', '❤️', '😻', '🐱'];
    
    document.addEventListener('click', (e) => {
      const emoji = clickEmojis[Math.floor(Math.random() * clickEmojis.length)];
      const effect = document.createElement('div');
      effect.className = 'click-effect';
      effect.textContent = emoji;
      effect.style.left = e.clientX + 'px';
      effect.style.top = e.clientY + 'px';
      document.body.appendChild(effect);
      setTimeout(() => effect.remove(), 1000);
    });

    // 浮动猫咪点击
    const cats = document.querySelectorAll('.floating-cat');
    const bubble = document.getElementById('cat-bubble');
    
    cats.forEach(cat => {
      cat.addEventListener('click', (e) => {
        e.stopPropagation();
        const message = cat.getAttribute('data-message');
        bubble.textContent = message;
        bubble.classList.remove('hidden');
        
        // 炸出特效
        for (let i = 0; i < 5; i++) {
          setTimeout(() => {
            const effect = document.createElement('div');
            effect.className = 'click-effect';
            effect.textContent = '💖';
            effect.style.left = (e.clientX + (Math.random() - 0.5) * 100) + 'px';
            effect.style.top = (e.clientY + (Math.random() - 0.5) * 100) + 'px';
            document.body.appendChild(effect);
            setTimeout(() => effect.remove(), 1000);
          }, i * 100);
        }
        
        setTimeout(() => bubble.classList.add('hidden'), 2000);
      });
    });

    // 互动按钮
    const interactiveBtns = document.querySelectorAll('.interactive-btn');
    interactiveBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const emoji = btn.getAttribute('data-emoji');
        for (let i = 0; i < 10; i++) {
          setTimeout(() => {
            const effect = document.createElement('div');
            effect.className = 'click-effect';
            effect.textContent = emoji;
            effect.style.left = (Math.random() * window.innerWidth) + 'px';
            effect.style.top = (Math.random() * window.innerHeight) + 'px';
            document.body.appendChild(effect);
            setTimeout(() => effect.remove(), 1000);
          }, i * 50);
        }
      });
    });

    // 主题切换
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });

    // 初始化主题
    if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }

    // 访客计数器模拟
    const visitorCount = document.getElementById('visitor-count');
    let count = parseInt(visitorCount.textContent);
    setInterval(() => {
      if (Math.random() > 0.7) {
        count++;
        visitorCount.textContent = count;
      }
    }, 5000);
  </script>
</Layout>
